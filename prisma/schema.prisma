generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Novel {
  id                  String               @id @default(cuid())
  title               String
  author              String
  description         String?              @db.Text
  coverUrl            String?
  status              NovelStatus          @default(ONGOING)
  publishStatus       String               @default("published")
  isAdult             Boolean              @default(false)
  isFeatured          Boolean              @default(false)
  authorId            String?
  sourceLocale        String               @default("zh-CN")
  viewCount           Int                  @default(0)
  favoriteCount       Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  chapters            Chapter[]
  favorites           Favorite[]
  translations        NovelTranslation[]
  categories          NovelCategory[]
  translationRequests TranslationRequest[]
  cards               NovelCard[]

  @@map("novels")
}

model NovelCard {
  id           String                 @id @default(cuid())
  novelId      String
  novel        Novel                  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  imageUrl     String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  translations NovelCardTranslation[]

  @@map("novel_cards")
}

model NovelCardTranslation {
  id          String    @id @default(cuid())
  cardId      String
  card        NovelCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  locale      String
  title       String
  description String    @db.Text
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([cardId, locale])
  @@map("novel_card_translations")
}

model Category {
  id     String          @id @default(cuid())
  slug   String          @unique
  novels NovelCategory[]

  @@map("categories")
}

model NovelCategory {
  novelId    String
  categoryId String
  novel      Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([novelId, categoryId])
  @@map("novel_categories")
}

model NovelTranslation {
  id          String @id @default(cuid())
  novelId     String
  locale      String
  title       String
  description String @db.Text
  status      String @default("published")
  novel       Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, locale])
  @@map("novel_translations")
}

model Chapter {
  id            String               @id @default(cuid())
  novelId       String
  title         String
  content       String               @db.Text
  order         Int
  publishStatus String               @default("published")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  novel         Novel                @relation(fields: [novelId], references: [id], onDelete: Cascade)
  translations  ChapterTranslation[]
  comments      Comment[]

  @@unique([novelId, order])
  @@map("chapters")
}

model ChapterTranslation {
  id        String  @id @default(cuid())
  chapterId String
  locale    String
  title     String
  content   String  @db.Text
  status    String  @default("published")
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, locale])
  @@map("chapter_translations")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  novelId   String
  createdAt DateTime @default(now())
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("favorites")
}

model TranslationRequest {
  id            String   @id @default(cuid())
  novelId       String
  novel         Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  targetLocale  String
  status        String   @default("pending")
  totalChapters Int      @default(0)
  doneChapters  Int      @default(0)
  triggerRunId  String?
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([novelId, targetLocale])
  @@map("translation_requests")
}

model Comment {
  id               String    @id @default(cuid())
  content          String    @db.Text
  authorId         String
  chapterId        String
  chapter          Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraphIndex   Int
  parentId         String?
  parent           Comment?  @relation("replies", fields: [parentId], references: [id])
  replies          Comment[] @relation("replies")
  isReadByAuthor   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)

  @@map("comments")
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}
