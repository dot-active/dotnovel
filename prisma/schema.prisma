generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Novel {
  id           String             @id @default(cuid())
  title        String
  author       String
  description  String?            @db.Text
  coverUrl     String?
  status       NovelStatus        @default(ONGOING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  chapters     Chapter[]
  favorites    Favorite[]
  translations NovelTranslation[]

  @@map("novels")
}

model NovelTranslation {
  id          String @id @default(cuid())
  novelId     String
  locale      String
  title       String
  description String @db.Text
  novel       Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([novelId, locale])
  @@map("novel_translations")
}

model Chapter {
  id           String               @id @default(cuid())
  novelId      String
  title        String
  content      String               @db.Text
  order        Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  novel        Novel                @relation(fields: [novelId], references: [id], onDelete: Cascade)
  translations ChapterTranslation[]

  @@unique([novelId, order])
  @@map("chapters")
}

model ChapterTranslation {
  id        String  @id @default(cuid())
  chapterId String
  locale    String
  title     String
  content   String  @db.Text
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, locale])
  @@map("chapter_translations")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  novelId   String
  createdAt DateTime @default(now())
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("favorites")
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}
